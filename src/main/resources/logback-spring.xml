<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<springProperty scope="context" name="applicationName"
					source="spring.application.name" defaultValue="credit-contract-manager"/>

	<appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="net.logstash.logback.encoder.LogstashEncoder">
			<customFields>{"service":"${applicationName}"}</customFields>
			<includeMdcKeyName>correlationId</includeMdcKeyName>
			<includeMdcKeyName>eventId</includeMdcKeyName>
		</encoder>
	</appender>

	<root level="INFO">
		<appender-ref ref="JSON_CONSOLE"/>
	</root>
</configuration>
